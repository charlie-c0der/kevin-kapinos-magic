<script setup lang="ts">
import { onMounted } from 'vue'
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

const scrollToExperience = () => {
  const element = document.getElementById('experience')
  if (element) {
    element.scrollIntoView({ behavior: 'smooth' })
  }
}

onMounted(() => {
  // Hero animations
  gsap.timeline()
    .from('.hero__label', { duration: 0.8, y: 30, opacity: 0 })
    .from('.hero__title', { duration: 1, y: 50, opacity: 0 }, '-=0.3')
    .from('.hero__description', { duration: 0.8, y: 30, opacity: 0 }, '-=0.5')
    .from('.hero__actions', { duration: 0.8, y: 30, opacity: 0 }, '-=0.3')
    .from('.hero__visual', { duration: 1, scale: 0.8, opacity: 0 }, '-=1')
    .from('.hero__venues', { duration: 0.8, y: 30, opacity: 0 }, '-=0.5')

  // Floating animation for brain visual
  gsap.to('.mind-visual', {
    y: -15,
    duration: 3,
    repeat: -1,
    yoyo: true,
    ease: 'power2.inOut'
  })

  // Neural network animation
  gsap.to('.neuron', {
    scale: 1.2,
    opacity: 0.8,
    duration: 2,
    repeat: -1,
    yoyo: true,
    stagger: 0.2,
    ease: 'power2.inOut'
  })

  // Section animations on scroll
  gsap.from('.experience__card', {
    scrollTrigger: '.experience',
    y: 80,
    opacity: 0,
    duration: 0.8,
    stagger: 0.2
  })

  gsap.from('.performance-card', {
    scrollTrigger: '.performances',
    y: 80,
    opacity: 0,
    duration: 0.8,
    stagger: 0.3
  })

  gsap.from('.testimonial-main', {
    scrollTrigger: '.testimonials',
    y: 50,
    opacity: 0,
    duration: 1
  })

  gsap.from('.testimonial-mini', {
    scrollTrigger: '.testimonials',
    y: 30,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15
  })
})
</script>

